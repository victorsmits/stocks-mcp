# PostgreSQL
POSTGRES_DB=stocks
POSTGRES_USER=stocks
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Public MCP listener
PUBLIC_PORT=8400
MCP_PUBLIC_URL=https://stock-mcp.example.com

# Google OAuth Web Application credentials
GOOGLE_CLIENT_ID=replace.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-client-secret

# Comma-separated, explicit allowlist
ALLOWED_GOOGLE_EMAILS=victor@example.com

# Generate with: openssl rand -hex 32
MCP_JWT_SIGNING_KEY=replace-with-a-long-random-signing-key

# Configure this exact Google redirect URI:
# https://stock-mcp.example.com/auth/callback
