# PostgreSQL
POSTGRES_DB=stocks
POSTGRES_USER=stocks
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Public listener for oauth2-proxy
PUBLIC_PORT=8400

# Google OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=replace.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-client-secret

# Must match the authorized redirect URI configured in Google Cloud
OAUTH2_REDIRECT_URL=https://stocks.example.com/oauth2/callback

# Generate with: openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=replace-with-a-32-byte-base64url-secret

# Set false only for local HTTP development
OAUTH2_PROXY_COOKIE_SECURE=true
